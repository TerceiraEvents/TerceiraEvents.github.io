source "https://rubygems.org"

gem "github-pages", group: :jekyll_plugins

# jekyll-seo-tag and jekyll-sitemap are bundled with github-pages, but
# listing them here makes the dependency intent explicit and surfaces
# them to local `bundle install` users running outside of github-pages.
group :jekyll_plugins do
  gem "jekyll-seo-tag"
  gem "jekyll-sitemap"
end
